{
	"name": "df_orders_analytics",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_curated_orders_parquet",
						"type": "DatasetReference"
					},
					"name": "orders"
				},
				{
					"dataset": {
						"referenceName": "ds_curated_order_items_parquet",
						"type": "DatasetReference"
					},
					"name": "orderitems"
				},
				{
					"dataset": {
						"referenceName": "ds_curated_payments_parquet",
						"type": "DatasetReference"
					},
					"name": "payments"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_serving_sales_daily_parquet",
						"type": "DatasetReference"
					},
					"name": "SinkSalesDaily"
				},
				{
					"dataset": {
						"referenceName": "ds_serving_customer_360_parquet",
						"type": "DatasetReference"
					},
					"name": "SinkCustomer360"
				}
			],
			"transformations": [
				{
					"name": "JoinOrdersOrderItems"
				},
				{
					"name": "JoinWithPayments"
				},
				{
					"name": "DeriveLineAmountSalesDate"
				},
				{
					"name": "FilterNonCancelled"
				},
				{
					"name": "AggSalesDaily"
				},
				{
					"name": "AggCustomer360"
				}
			],
			"scriptLines": [
				"source(output(",
				"          order_id as string,",
				"          customer_id as string,",
				"          order_date as string,",
				"          order_status as string,",
				"          sales_channel as string,",
				"          payment_method as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> orders",
				"source(output(",
				"          order_item_id as string,",
				"          order_id as string,",
				"          product_id as string,",
				"          quantity as string,",
				"          unit_price as string,",
				"          discount_pct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> orderitems",
				"source(output(",
				"          payment_id as string,",
				"          order_id as string,",
				"          payment_date as string,",
				"          amount as string,",
				"          payment_status as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> payments",
				"orders, orderitems join(orders@order_id == orderitems@order_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinOrdersOrderItems",
				"JoinOrdersOrderItems, payments join(orders@order_id == payments@order_id,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinWithPayments",
				"JoinWithPayments derive(sales_date = toDate(order_date),",
				"          line_amount = toDecimal(toDouble(quantity) * toDouble(unit_price) * (1 - toDouble(discount_pct)), 18, 2)) ~> DeriveLineAmountSalesDate",
				"DeriveLineAmountSalesDate filter(order_status != 'Cancelled') ~> FilterNonCancelled",
				"FilterNonCancelled aggregate(groupBy(sales_date,",
				"          sales_channel),",
				"     orders = countDistinct(orders@order_id),",
				"          customers = countDistinct(customer_id),",
				"          total_revenue = sum(line_amount)) ~> AggSalesDaily",
				"FilterNonCancelled aggregate(groupBy(customer_id),",
				"     total_orders = countDistinct(orders@order_id),",
				"          total_revenue = sum(line_amount)) ~> AggCustomer360",
				"AggSalesDaily sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkSalesDaily",
				"AggCustomer360 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkCustomer360"
			]
		}
	}
}